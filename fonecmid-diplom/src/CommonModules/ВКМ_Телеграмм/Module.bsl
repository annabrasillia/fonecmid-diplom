#Область ПрограммныйИнтерфейс

// Отправляет накопленные уведомления из справочника-очереди в Telegram.
// Вызывается из регламентного задания.
Процедура ВКМ_ОтправитьУведомленияВТелеграмм() Экспорт
	
	// 1. Получаем настройки из констант
	Токен = Константы.ВКМ_ТокенУправленияТГБотом.Получить();
	ИдентификаторЧата = Константы.ВКМ_ИдентификаторГруппыДляОповещения.Получить();
	
	// 2. Валидация настроек
	Если Не ЗначениеЗаполнено(Токен) Или Не ЗначениеЗаполнено(ИдентификаторЧата) Тогда
		ВКМ_ЗаписатьОшибкуВЖурнал("Настройки интеграции не заполнены (токен или ID чата).");
		Возврат;
	КонецЕсли;
	
	// 3. Получаем очередь сообщений
	Выборка = ВКМ_ПолучитьУведомленияДляОтправки();
	
	Пока Выборка.Следующий() Цикл
		
		// 4. Отправка через современный HTTP-запрос
		Ответ = ВКМ_ОтправитьСообщениеВТелеграмм(Выборка.ВКМ_ТекстСообщения, Токен, ИдентификаторЧата);
		
		Если Ответ <> Неопределено И Ответ.КодСостояния = 200 Тогда
			// Успешно отправлено — удаляем из очереди
			Попытка
				УведомлениеОбъект = Выборка.Ссылка.ПолучитьОбъект();
				Если УведомлениеОбъект <> Неопределено Тогда
					УведомлениеОбъект.Удалить();
				КонецЕсли;
			Исключение
				ВКМ_ЗаписатьОшибкуВЖурнал("Не удалось удалить уведомление: " + ОписаниеОшибки());
			КонецПопытки;
		ИначеЕсли Ответ <> Неопределено Тогда
			// Ошибка API Telegram
			ОписаниеОшибкиAPI = Ответ.ПолучитьТелоКакСтроку();
			ВКМ_ЗаписатьОшибкуВЖурнал("Ошибка API Telegram: " + ОписаниеОшибкиAPI);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет непосредственную отправку сообщения через Telegram Bot API
Функция ВКМ_ОтправитьСообщениеВТелеграмм(Знач ТекстСообщения, Знач Токен, Знач ИдентификаторЧата)
	
	Перем Соединение, HTTPЗапрос, Ответ;
	
	Попытка 
		// Используем таймаут 10 секунд и современное защищенное соединение
		Защита = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
		Соединение = Новый HTTPСоединение("api.telegram.org", , , , , 10, Защита);
		
		// Формируем структуру JSON для тела запроса
		Данные = Новый Структура("chat_id, text", ИдентификаторЧата, ТекстСообщения);
		
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку();
		ЗаписатьJSON(ЗаписьJSON, Данные);
		ТелоЗапроса = ЗаписьJSON.Закрыть();
		
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		
		URL = СтрШаблон("/bot%1/sendMessage", Токен);
		HTTPЗапрос = Новый HTTPЗапрос(URL, Заголовки);
		HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8);
		
		// Используем САМЫЙ АКТУАЛЬНЫЙ метод платформы ОтправитьЗапрос (вместо устаревших)
		Ответ = Соединение.ОтправитьЗапрос(HTTPЗапрос);
		
		Возврат Ответ;
		
	Исключение
		ВКМ_ЗаписатьОшибкуВЖурнал("Критическая ошибка HTTP: " + ОписаниеОшибки());		
		Возврат Неопределено;
	КонецПопытки;
		
КонецФункции

// Получает список всех сообщений, ожидающих отправки
Функция ВКМ_ПолучитьУведомленияДляОтправки()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ

		|	ВКМ_УведомленияТГБоту.Ссылка КАК Ссылка,
		|	ВКМ_УведомленияТГБоту.ВКМ_ТекстСообщения КАК ВКМ_ТекстСообщения
		|ИЗ
		|	Справочник.ВКМ_УведомленияТГБоту КАК ВКМ_УведомленияТГБоту";
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Служебная процедура для логирования ошибок в Журнал регистрации
Процедура ВКМ_ЗаписатьОшибкуВЖурнал(ТекстОшибки)
	ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
		"ВКМ_Телеграмм.Отправка",
		УровеньЖурналаРегистрации.Ошибка,
		,
		,
		ТекстОшибки);
КонецПроцедуры

#КонецОбласти
