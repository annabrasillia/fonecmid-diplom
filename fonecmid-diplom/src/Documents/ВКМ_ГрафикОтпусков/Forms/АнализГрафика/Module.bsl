#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	АдресИзХранилища = "";
	
	// Метод "Свойство" ищет ключ в структуре параметров, 
	// даже если он не описан в метаданных формы.
	Если Параметры.Свойство("АдресВХранилище", АдресИзХранилища) Тогда
		
		Если ЗначениеЗаполнено(АдресИзХранилища) Тогда
			ТЗ_Данные = ПолучитьИзВременногоХранилища(АдресИзХранилища);
			
			Если ТипЗнч(ТЗ_Данные) = Тип("ТаблицаЗначений") Тогда
				ОбновитьДиаграммуГанта(ТЗ_Данные);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьДиаграммуГанта(ТЗ_Данные)
	
	// Очищаем диаграмму перед заполнением
	Диаграмма.Очистить();
	
	Диаграмма.АвтоОпределениеПолногоИнтервала = Истина;
	
	
	// 2. Настраиваем структуру: Точки (Сотрудники) и Серии (Отпуска)
	// В диаграмме Ганта обычно одна серия, а периоды добавляются как интервалы
	СерияОтпуск = Диаграмма.Серии.Добавить();
	СерияОтпуск.Текст = "Отпуска";
	СерияОтпуск.Цвет = WebЦвета.Аквамарин;
	
	Для Каждого СтрокаДанных Из ТЗ_Данные Цикл
		
		// Создаем или находим точку (Сотрудника)
		ТочкаСотрудник = Диаграмма.УстановитьТочку(СтрокаДанных.Сотрудник);
		ТочкаСотрудник.Текст = Строка(СтрокаДанных.Сотрудник); 
		
		// Создаем интервал (полоску на графике)
		Значение = Диаграмма.ПолучитьЗначение(ТочкаСотрудник, СерияОтпуск);
		Интервал = Значение.Добавить();
		
		Интервал.Текст = Строка(СтрокаДанных.Сотрудник);
		Интервал.Начало = СтрокаДанных.ДатаНачала;
		Интервал.Конец  = СтрокаДанных.ДатаОкончания;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
