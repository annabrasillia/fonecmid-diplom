
#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	АнализГрафика();
	ЗаполнитьСотрудников();
	// Настройка программного условного оформления
	УсловноеОформление.Элементы.Очистить();
	
	ЭлементОформления = УсловноеОформление.Элементы.Добавить();
	
	// 1. Что делаем: красим текст в красный 
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ПоясняющийОшибкуТекст);
	
	
	// 2. Условие: когда реквизит формы "ПревышениеЛимита" равен Истина
	ЭлементУсловия = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементУсловия.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ОтпускаСотрудников.ПревышениеЛимита");
	ЭлементУсловия.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементУсловия.ПравоеЗначение = Истина;
	
	// 3. Где применяем: ко всей строке таблицы ОтпускаСотрудников
	ОформляемоеПоле = ЭлементОформления.Поля.Элементы.Добавить();
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("ОтпускаСотрудников");
	
	// Если форма открывается с уже заполненными данными (например, при просмотре), 
	// нужно сразу рассчитать лимиты для подсветки.
	ПересчитатьЛимитыНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыОтпускаСотрудников

&НаКлиенте
Процедура ОтпускаСотрудниковПриИзменении(Элемент) Экспорт
	// Вызываем пересчет при любом изменении в таблице
	ПересчитатьЛимитыНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтпускаСотрудниковДатаНачалаПриИзменении(Элемент) Экспорт
	ПересчитатьЛимитыНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтпускаСотрудниковДатаОкончанияПриИзменении(Элемент) Экспорт
	ПересчитатьЛимитыНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура АнализГрафика()
	// 1. Создаем команду формы
	ИмяКоманды = "АнализГрафика";
	КомандаЗаполнения = Команды.Добавить(ИмяКоманды);
	КомандаЗаполнения.Действие  = "АнализГрафикаНаКлиенте";
	КомандаЗаполнения.Заголовок = "Анализ графика";
	
	// 2. Добавляем кнопку на командную панель таблицы
	// Проверьте имя элемента командной панели в вашей форме 
	ЭлементПанель = Элементы.ГодАнализ; 
	НоваяКнопка = Элементы.Добавить("КнопкаАнализГрафика", Тип("КнопкаФормы"), ЭлементПанель);
	НоваяКнопка.ИмяКоманды = ИмяКоманды;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСотрудников()
	// 1. Создаем команду формы
	ИмяКоманды = "ЗаполнитьСотрудников";
	КомандаЗаполнения = Команды.Добавить(ИмяКоманды);
	КомандаЗаполнения.Действие  = "ЗаполнитьСотрудниковНаКлиенте";
	КомандаЗаполнения.Заголовок = "Заполнить сотрудников";
	
	// 2. Добавляем кнопку на командную панель таблицы
	// Проверьте имя элемента командной панели в вашей форме 
	ЭлементПанель = Элементы.ОтпускаСотрудниковКоманднаяПанель; 
	НоваяКнопка = Элементы.Добавить("КнопкаЗаполнитьСотрудников", Тип("КнопкаФормы"), ЭлементПанель);
	НоваяКнопка.ИмяКоманды = ИмяКоманды;
	
КонецПроцедуры

&НаКлиенте
Процедура АнализГрафикаНаКлиенте(Команда) Экспорт
	
	АдресВХранилище = ПоместитьВоВременноеХранилищеНаСервере();
	ПараметрыФормы = Новый Структура("АдресВХранилище", АдресВХранилище);
	ОткрытьФорму("Документ.ВКМ_ГрафикОтпусков.Форма.АнализГрафика", ПараметрыФормы, ЭтотОбъект);

КонецПроцедуры


&НаСервере
Функция ПоместитьВоВременноеХранилищеНаСервере()

	Адрес = ПоместитьВоВременноеХранилище(Объект.ОтпускаСотрудников.Выгрузить( ,
        "Сотрудник,ДатаНачала,ДатаОкончания"), УникальныйИдентификатор);
    Возврат Адрес;


КонецФункции

&НаКлиенте
Процедура ЗаполнитьСотрудниковНаКлиенте(Команда) Экспорт
	ЗаполнитьСотрудниковНаСервере();
	ПересчитатьЛимитыНаСервере();
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьСотрудниковНаСервере()
	
// Очищаем таблицу перед заполнением (или можно добавлять в конец)
	Объект.ОтпускаСотрудников.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ


		|	Пользователи.Ссылка КАК Сотрудник
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи


		|ГДЕ
		|	НЕ Пользователи.ПометкаУдаления
		|	И НЕ Пользователи.Наименование ПОДОБНО ""%Не указан%""
		|	И НЕ Пользователи.Наименование ПОДОБНО ""%Сервер%""";

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.ОтпускаСотрудников.Добавить();
		НоваяСтрока.Сотрудник = Выборка.Сотрудник;
		
		// Можно сразу подставить начало года из реквизита "Год" шапки
		Если ЗначениеЗаполнено(Объект.Год) Тогда
			НоваяСтрока.ДатаНачала = Дата(Объект.Год, 1, 1);
			НоваяСтрока.ДатаОкончания = Дата(Объект.Год, 1, 1);
		КонецЕсли;
	КонецЦикла;


КонецПроцедуры



&НаСервере
Процедура ПересчитатьЛимитыНаСервере()
	
	// 1. Рассчитываем длительность каждой строки для вывода пользователю
	Для Каждого СтрокаФормы Из Объект.ОтпускаСотрудников Цикл
		Если ЗначениеЗаполнено(СтрокаФормы.ДатаНачала) И ЗначениеЗаполнено(СтрокаФормы.ДатаОкончания) Тогда
			СтрокаФормы.КоличествоДнейВДокументе = (НачалоДня(СтрокаФормы.ДатаОкончания) - НачалоДня(СтрокаФормы.ДатаНачала)) / 86400 + 1;
		Иначе
			СтрокаФормы.КоличествоДнейВДокументе = 0;
		КонецЕсли;
	КонецЦикла;
	
	// 2. Считаем общую сумму дней по каждому сотруднику внутри документа
	ТЗ_Итоги = Объект.ОтпускаСотрудников.Выгрузить();
	ТЗ_Итоги.Свернуть("Сотрудник", "КоличествоДнейВДокументе");
	
	// 3. Проставляем флаг превышения для условного оформления
	Для Каждого СтрокаФормы Из Объект.ОтпускаСотрудников Цикл
		Если Не ЗначениеЗаполнено(СтрокаФормы.Сотрудник) Тогда
			СтрокаФормы.ПревышениеЛимита = Ложь;
			Продолжить;
		КонецЕсли;
		
		СтрокаИтога = ТЗ_Итоги.Найти(СтрокаФормы.Сотрудник, "Сотрудник");
		// Если сумма дней по сотруднику во всем документе > 28, ставим Истина
		СтрокаФормы.ПревышениеЛимита = (СтрокаИтога <> Неопределено И СтрокаИтога.КоличествоДнейВДокументе > 28);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти




