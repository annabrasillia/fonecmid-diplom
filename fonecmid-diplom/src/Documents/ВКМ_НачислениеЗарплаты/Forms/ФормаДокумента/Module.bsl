#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// 1. Создаем команду формы
	ИмяКоманды = "ЗаполнитьСотрудников";
	КомандаЗаполнения = Команды.Добавить(ИмяКоманды);
	КомандаЗаполнения.Действие  = "ЗаполнитьСотрудниковНаКлиенте";
	КомандаЗаполнения.Заголовок = "Заполнить сотрудников";
	
	// 2. Добавляем кнопку на командную панель таблицы
	// Проверьте имя элемента командной панели в вашей форме (обычно НачисленияЗПКоманднаяПанель)
	ЭлементПанель = Элементы.НачисленияЗПКоманднаяПанель; 
	НоваяКнопка = Элементы.Добавить("КнопкаЗаполнитьСотрудников", Тип("КнопкаФормы"), ЭлементПанель);
	НоваяКнопка.ИмяКоманды = ИмяКоманды;
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовТаблицыФормыНачисленияЗП
&НаКлиенте
Процедура НачисленияЗПВидРасчетаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	// Формируем список того, что МОЖНО выбирать в этом документе
	МассивРазрешенных = Новый Массив;
	МассивРазрешенных.Добавить(ПредопределенноеЗначение("ПланВидовРасчета.ВКМ_ОсновныеНачисления.Оклад"));
	МассивРазрешенных.Добавить(ПредопределенноеЗначение("ПланВидовРасчета.ВКМ_ОсновныеНачисления.Отпуск"));
	МассивРазрешенных.Добавить(ПредопределенноеЗначение("ПланВидовРасчета.ВКМ_ДополнительныеНачисления.ПремияПроцентом"));
	
	// Создаем фиксированный параметр отбора
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", МассивРазрешенных);
	
	// Оборачиваем в фиксированный массив, как того требует платформа
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(НовыйПараметр);
	
	// Устанавливаем параметры выбора для элемента формы
	Элемент.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);

КонецПроцедуры
#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗаполнитьСотрудниковНаКлиенте(Команда) Экспорт
	ЗаполнитьСотрудниковНаСервере();
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьСотрудниковНаСервере()
	
	// Очищаем таблицу перед заполнением
	Объект.НачисленияЗП.Очистить();
	
	// 1. Получаем период из шапки документа
	НачалоПериода = НачалоМесяца(Объект.ПериодРегистрации);
	КонецПериода = КонецМесяца(Объект.ПериодРегистрации);
	
	// 2. ЗАПРОС: Получаем всех сотрудников (для Оклада) 
	// и тех, кто работал по обслуживанию (для Премии)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ

		|	Пользователи.Ссылка КАК Сотрудник,
		|	ЗНАЧЕНИЕ(ПланВидовРасчета.ВКМ_ОсновныеНачисления.Оклад) КАК ВидРасчета
		|ИЗ

		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	НЕ Пользователи.ПометкаУдаления

		|	И НЕ Пользователи.Наименование ПОДОБНО ""%Не указан%""
		|	И НЕ Пользователи.Наименование ПОДОБНО ""%Сервер%""
		|	И НЕ Пользователи.Наименование = """"

		|
		|ОБЪЕДИНИТЬ ВСЕ
		|

		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВКМ_ВыполненныеРаботы.Сотрудник,
		|	ЗНАЧЕНИЕ(ПланВидовРасчета.ВКМ_ДополнительныеНачисления.ПремияПроцентом)

		|ИЗ
		|	РегистрНакопления.ВКМ_ВыполненныеСотрудникомРаботы.Обороты(&НачалоПериода, &КонецПериода, , ) КАК ВКМ_ВыполненныеРаботы
		|ГДЕ
		|	ВКМ_ВыполненныеРаботы.ЧасовКОплатеОборот > 0";

	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ОсновнойГрафик = Справочники.ВКМ_ГрафикиРаботы.НайтиПоНаименованию("Пятидневка");
	
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрока = Объект.НачисленияЗП.Добавить();
		НоваяСтрока.Сотрудник = Выборка.Сотрудник;
		НоваяСтрока.ВидРасчета = Выборка.ВидРасчета;
		
		// Для окладов заполняем график, для премий он обычно не нужен
		Если Выборка.ВидРасчета = ПланыВидовРасчета.ВКМ_ОсновныеНачисления.Оклад Тогда
			НоваяСтрока.ГрафикРаботы = ОсновнойГрафик;
		КонецЕсли;
		
		// Заполняем даты из периода регистрации
		НоваяСтрока.ДатаНачала = НачалоПериода;
		НоваяСтрока.ДатаОкончания = КонецПериода;
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

