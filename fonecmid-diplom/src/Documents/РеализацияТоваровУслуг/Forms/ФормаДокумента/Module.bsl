//++ВКМ Салтанова (Расширение списка разрешенных видов договоров)
//Добавление области ОбработчикиСобытийЭлементовШапкиФормы
//Добавление процедуры на клиенте ДоговорНачалоВыбора
#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДоговорНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	// Формируем массив разрешенных видов договоров
	СписокВидов = Новый Массив;
	СписокВидов.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание"));
	СписокВидов.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.Покупатель"));
	СписокВидов.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.Поставщик"));
	
	// Создаем структуру отбора
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ВидДоговора", СписокВидов);
	СтруктураОтбора.Вставить("Организация", Объект.Организация);
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		СтруктураОтбора.Вставить("Владелец", Объект.Контрагент);
	КонецЕсли;
	
	// Помещаем отбор в итоговые параметры формы
	ПараметрыФормы = Новый Структура("Отбор", СтруктураОтбора);
	
	// Открываем форму выбора
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.ФормаВыбора", ПараметрыФормы, Элемент);

КонецПроцедуры

#КонецОбласти
	//-- ВКМ

